# Google Cloud Infrastructure Manager デプロイメント用 環境変数設定

# Google Cloud プロジェクトID
GCP_PROJECT_ID=your-project-id

# デプロイメントのロケーション (例: us-central1, asia-northeast1)
GCP_LOCATION=us-central1

# デプロイメント名
DEPLOYMENT_NAME=gcp-billing-alert-deployment

# Terraformファイルのディレクトリパス
TF_DIR=.

# terraform.tfvarsファイルのパス
TF_VARS_FILE=./terraform.tfvars

# Google Cloud 認証
# オプション1: GOOGLE_APPLICATION_CREDENTIALSで認証キーファイルを指定
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# オプション2: gcloud CLIで事前に認証
# gcloud auth application-default login
