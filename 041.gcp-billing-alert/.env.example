# Google Cloud Infrastructure Manager デプロイメント用 環境変数設定

# Google Cloud プロジェクトID
GCP_PROJECT_ID=your-project-id

# デプロイメントのロケーション (例: us-central1, asia-northeast1)
GCP_LOCATION=us-central1

# デプロイメント名
DEPLOYMENT_NAME=gcp-billing-alert-deployment

# Infrastructure Manager が Terraform 実行に使用するサービスアカウント（必須）
GCP_SERVICE_ACCOUNT=infra-manager-runner@your-project-id.iam.gserviceaccount.com

# Infrastructure Manager の Terraform ソース (事前にCloud Storageへアップロード)
# 例: gs://my-infra-source-bucket/gcp-billing-alert/terraform.zip
GCS_SOURCE_URI=gs://your-source-bucket/path/to/terraform.zip

# true の場合、deploy.ts が TF_DIR を zip 化して GCS_SOURCE_URI へアップロードします
AUTO_UPLOAD_TERRAFORM=true

# zip化対象のTerraformファイル配置ディレクトリ
TF_DIR=.

# Cloud Buildログ・アーティファクトの保存先 (任意 / 事前作成バケット)
# 例: gs://my-infra-artifacts-bucket/config-artifacts
# ARTIFACTS_GCS_BUCKET=gs://your-artifacts-bucket/optional-folder

# Terraform input variables
TF_PROJECT_ID=your-gcp-project-id
TF_BILLING_ACCOUNT_ID=XXXXXX-XXXXXX-XXXXXX
TF_ALERT_EMAIL_ADDRESSES=["admin@example.com","finance@example.com"]
TF_BUDGET_AMOUNT=1000
TF_CURRENCY_CODE=JPY
TF_BUDGET_DISPLAY_NAME=Monthly-Billing-Alert
TF_ALERT_THRESHOLD_PERCENTAGES=[50,80,100]
TF_REGION=asia-northeast1

# 必要に応じて .env ファイル自体のパスを変更
# ENV_FILE=./.env

# Google Cloud 認証
# オプション1: GOOGLE_APPLICATION_CREDENTIALSで認証キーファイルを指定
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# オプション2: gcloud CLIで事前に認証
# gcloud auth application-default login
