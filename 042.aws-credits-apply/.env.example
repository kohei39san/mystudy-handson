# ログイン開始URL（必須）
# 例: https://signin.aws.amazon.com/signin
LOGIN_URL=https://signin.aws.amazon.com/signin

# ログイン完了後に待機する URL（省略時はクレジット適用画面）
# 文字列一致または Playwright の URL パターン（例: **/costmanagement/home*）を指定可能
READY_URL=https://*.console.aws.amazon.com/console/home*

# 起動するブラウザチャネル: chrome / msedge
BROWSER_CHANNEL=chrome

# ログイン待機タイムアウト（ミリ秒）
LOGIN_TIMEOUT_MS=300000
